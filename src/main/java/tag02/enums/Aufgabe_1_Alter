Musterlösung

Aufgabe: Enumerationen in Java – Enum-Klasse „Alter“

⸻

1. Implementierung der Enum-Klasse

package template;

public enum Alter {

    NEUGEBOREN(0),
    VOLLJÄHRIG(18),
    SENIOR(60);

    private final int alterZahl;

    // Konstruktor der Enum
    private Alter(int alterZahl) {
        this.alterZahl = alterZahl;
    }

    // Getter-Methode
    public int getAlterZahl() {
        return alterZahl;
    }

    // Sucht eine Enum-Konstante anhand einer Zahl
    public static Alter getAlter(int zahl) {
        for (Alter a : Alter.values()) {
            if (a.alterZahl == zahl) {
                return a;
            }
        }
        return null;
    }

    // Sucht eine Enum-Konstante anhand des Namens
    public static int getAlterByName(String name) {
        for (Alter a : Alter.values()) {
            if (a.name().equalsIgnoreCase(name)) {
                return a.alterZahl;
            }
        }
        return 0;
    }
}


⸻

2. Beispielprogramm zur Anwendung der Enumeration

package template;

public class Enumerationen {

    public static void main(String[] args) {

        // Zugriff auf eine Enum-Konstante
        Alter a = Alter.VOLLJÄHRIG;

        System.out.println("Konstante: " + a);
        System.out.println("Alter: " + a.getAlterZahl());

        System.out.println();

        // Suche nach Enum über Zahl
        Alter gefunden = Alter.getAlter(18);

        if (gefunden != null) {
            System.out.println("Gefunden über Zahl: " + gefunden);
        } else {
            System.out.println("Keine passende Konstante gefunden.");
        }

        System.out.println();

        // Suche nach Enum über Namen
        int wert = Alter.getAlterByName("senior");
        System.out.println("Alter von 'senior': " + wert);

        System.out.println();

        // Ausgabe aller Enum-Werte
        System.out.println("Alle Alterskategorien:");

        for (Alter alter : Alter.values()) {
            System.out.println(alter + " -> " + alter.getAlterZahl());
        }
    }
}


